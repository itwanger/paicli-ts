{
  "name": "paicli-ts",
  "version": "0.1.0",
  "description": "PaiCLI — Terminal AI Agent in TypeScript",
  "type": "module",
  "bin": {
    "paicli": "./dist/bin/paicli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/entrypoints/sdk.js"
  },
  "files": [
    "dist/",
    "prompts/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/bin/paicli.js",
    "paicli": "tsx ./bin/paicli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ bin/",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "terminal",
    "llm",
    "tui"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.3",
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "undici": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
